GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- AI Classification Provider (Check 4: Auto Cost Code With Manual Values) ---
# The server auto-detects which provider to use based on which vars are set.
# Priority: Azure OpenAI > OpenAI direct > regex stub fallback

# Option A: OpenAI direct (for PoC / personal use)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Option B: Azure OpenAI (for client/production environment)
# Takes priority over OPENAI_API_KEY when all three vars below are set.
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=YOUR_AZURE_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o
